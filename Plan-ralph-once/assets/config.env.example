# Ralph Once Configuration
# Copy to .env, fill in values, then: source .env
# Same variables as ralph-loop. Additional ralph-once variable:

# Override to target a specific issue (leave unset to auto-select)
# RALPH_ISSUE_NUMBER=42

# Core
RALPH_DRAFT_PR=true
RALPH_HALT_ON_GATE_FAIL=false
RALPH_ISSUE_LABEL=ralph
RALPH_BLOCKED_LABEL=blocked
RALPH_PROGRESS_FILE=progress.txt
RALPH_BRANCH_PREFIX=ralph

# Agent
RALPH_AGENT_CMD=claude
RALPH_AGENT_TIMEOUT=600

# Gates
RALPH_GATE_TYPECHECK_ENABLED=true
RALPH_TYPECHECK_CMD="mypy ."
RALPH_GATE_LINT_ENABLED=true
RALPH_LINT_CMD="ruff check ."
RALPH_GATE_TEST_ENABLED=true
RALPH_TEST_CMD="pytest"
RALPH_GATE_COVERAGE_ENABLED=false
RALPH_COVERAGE_CMD="pytest --cov"
RALPH_COVERAGE_THRESHOLD=80
RALPH_GATE_DUPLICATION_ENABLED=false
RALPH_DUPLICATION_CMD="jscpd ."
RALPH_GATE_ENTROPY_ENABLED=false
RALPH_ENTROPY_CMD=""

# GitHub
RALPH_PR_LABELS=ralph
RALPH_COMMIT_PREFIX=[ralph]
